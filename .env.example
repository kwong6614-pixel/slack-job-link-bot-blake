# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Slack (create app at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
# Optional: channel ID for credential-expiry alerts (e.g. C0123ABCDEF)
SLACK_ALERT_CHANNEL=

# Google Sheets OAuth (same credentials used for refresh token flow)
# Refresh token expiry:
# - OAuth app in Testing: tokens expire after 7 days
# - Published app: revoked after ~6 months unused, user revocation, or password change
# - invalid_grant = expired, revoked, or client ID/secret mismatch
# Regenerate GOOGLE_REFRESH_TOKEN in Vercel when invalid_grant appears in logs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEETS_ID=

# Supabase PostgreSQL (stores JD analysis prompt)
DATABASE_URL=
